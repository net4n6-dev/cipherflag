NETWORK_INTERFACE={{.NetworkInterface}}
POSTGRES_PASSWORD={{.PostgresPassword}}
{{- if .VenafiEnabled}}
VENAFI_ENABLED=true
VENAFI_PLATFORM={{.VenafiPlatform}}
{{- if eq .VenafiPlatform "cloud"}}
VENAFI_API_KEY={{.VenafiAPIKey}}
VENAFI_REGION={{.VenafiRegion}}
{{- else}}
VENAFI_BASE_URL={{.VenafiBaseURL}}
VENAFI_CLIENT_ID={{.VenafiClientID}}
VENAFI_REFRESH_TOKEN={{.VenafiRefreshToken}}
VENAFI_FOLDER={{.VenafiFolder}}
{{- end}}
{{- end}}
